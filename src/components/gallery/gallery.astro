---
import type { ImageMetadata } from "astro";

interface GalleryImage {
  image_path: string;
  alt_text: string;
}

interface Props {
  images?: GalleryImage[];
}

const { images = [] } = Astro.props;

// Build-time resolution for images that live in the repo. Freshly uploaded
// paths won't be in the glob — they fall back to the raw path, which the
// Visual Editor resolves for preview. Plain <img> (not <Picture>) so the
// client-side re-render can set `src` directly on new uploads.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,svg,webp,avif}",
  { eager: true },
);

const resolve = (path: string) => allImages[path]?.default?.src ?? path;
---

<section class="py-12 md:py-20">
  {/* `relative` anchors the floating uploader pill to this component's corner.
      The uploader sits *outside* the images array (a sibling of it) so it never
      participates in the grid — the grid renders exactly as it will in prod,
      where no uploader exists. */}
  <div class="mx-auto max-w-6xl px-8 relative">
    <div
      data-editable="array"
      data-prop="images"
      class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {
        images.map((image) => (
          <figure
            data-editable="array-item"
            class="overflow-hidden rounded-lg bg-gray-50">
            <img
              data-editable="image"
              data-prop-src="image_path"
              data-prop-alt="alt_text"
              src={resolve(image.image_path)}
              alt={image.alt_text}
              loading="lazy"
              class="w-full h-48 object-contain"
            />
          </figure>
        ))
      }
    </div>

    <multi-image-uploader></multi-image-uploader>
  </div>
</section>

<style is:global>
  /* The element is only ever registered (`customElements.define`) inside the
     Visual Editor, so `:defined` is true there and false in production —
     no dependency on a body class that may or may not be present. */
  multi-image-uploader {
    display: none;
  }
  /* Floats in the component's top-right corner, over the grid — an editor-only
     affordance that never affects the production layout. */
  multi-image-uploader:defined {
    display: block;
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
  }
</style>
